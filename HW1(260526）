    What is hash collision
    
    ```java
    import java.util.*;
    
    public class HashCollision {
    
        // A deliberately bad hashCode because everything goes to bucket 0!
        static class BadKey {
            String value;
            BadKey(String v) { this.value = v; }
    
            @Override
            public int hashCode() { return 1; } // all keys → same bucket!
    
            @Override
            public boolean equals(Object o) {
                if (this == o) return true;
                if (!(o instanceof BadKey)) return false;
                return value.equals(((BadKey) o).value);
            }
    
            @Override
            public String toString() { return value; }
        }
    
        public static void main(String[] args) {
            Map bad = new HashMap<>();
            // All three collide into bucket 1 → forms a chain/tree
            bad.put(new BadKey("x"), "X");
            bad.put(new BadKey("y"), "Y");
            bad.put(new BadKey("z"), "Z");
    
            // Still correct because equals() distinguishes them
            System.out.println("x → " + bad.get(new BadKey("x"))); // X
            System.out.println("y → " + bad.get(new BadKey("y"))); // Y
            // But O(n) lookup instead of O(1) — terrible performance!
    
            // Good key: String has a well-distributed hashCode
            Map good = new HashMap<>();
            good.put("x", "X");
            good.put("y", "Y");
            good.put("z", "Z");
            // Likely 3 separate buckets O(1) lookup
            System.out.println("Good map: " + good.get("x")); // X
        }
    }
