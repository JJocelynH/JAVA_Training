    String vs StringBuilder vs StringBuffer
    
    ```java
    public class StringComparison {
        public static void main(String[] args) {
    
            // String: immutable
            String s = "Hello";
            s = s + " World"; // creates a NEW String object each time
            System.out.println(s); // Hello World
    
            // Identity check: same literal → same pool object
            String a = "java";
            String b = "java";
            System.out.println(a == b);       // true (string pool)
            System.out.println(a.equals(b));  // true
    
            String c = new String("java");
            System.out.println(a == c);       // false (heap object)
            System.out.println(a.equals(c));  // true — always use equals()!
    
            // BAD: O(n²) — creates n intermediate String objects
            String bad = "";
            for (int i = 0; i < 5; i++) {
                bad += i; // new String each iteration!
            }
            System.out.println("Bad: " + bad);
    
            // GOOD: StringBuilder — O(n), single buffer
            StringBuilder sb = new StringBuilder();
            for (int i = 0; i < 5; i++) {
                sb.append(i);
            }
            sb.insert(0, "nums: ");   // insert at position
            sb.reverse();              // reverse in place
            System.out.println("SB: " + sb.toString());
    
            sb.delete(0, 5);           // delete range
            System.out.println("After delete: " + sb);
    
            // StringBuffer: thread-safe (synchronized), same API as StringBuilder
            StringBuffer buf = new StringBuffer();
            buf.append("thread");
            buf.append("-safe");
            System.out.println("Buffer: " + buf.toString());
    
            // Performance note:
            // String concat in loop: ~O(n²) time & memory
            // StringBuilder.append in loop: O(n) — always prefer this
        }
    }
