import java.util.function.*;

public class FunctionalDemo {
    public static void main(String[] args) {

        // Predicate: is the name longer than 5 characters?
        Predicate<String> isLong = s -> s.length() > 5;

        // Supplier: provides a name
        Supplier<String> nameSupplier = () -> "Jocelyn";

        // Function: converts name to uppercase
        Function<String, String> toUpper = s -> s.toUpperCase();

        // Consumer: prints a greeting
        Consumer<String> greet = s -> System.out.println("Hello, " + s + "!");

 

        String name = nameSupplier.get();          

        if (isLong.test(name)) {                    
            String upper = toUpper.apply(name);     
            greet.accept(upper);                    
        }
    }
}
```

