    How does HashMap work
    
    ```java
    import java.util.*;
    
    public class HowHashMapWorks {
        public static void main(String[] args) {
            Map map = new HashMap<>();
    
            // Step 1: hashCode("name") → index in internal array
            // Step 2: store entry at that bucket
            map.put("name", "Alice");
            map.put("city", "NYC");
            map.put("job",  "Engineer");
    
            // Step 3: on get, recompute index, walk bucket, equals() to match
            System.out.println(map.get("name")); // Alice
    
            // Default capacity: 16 buckets, load factor: 0.75
            // When size > 16 * 0.75 = 12, HashMap resizes (doubles) and rehashes
    
            // Demonstrating hash distribution:
            String[] keys = {"a", "b", "c", "d"};
            for (String k : keys) {
                int hash = k.hashCode();
                int bucket = hash & (16 - 1); // simulates (n-1) & hash
                System.out.printf("key='%s' hashCode=%d bucket=%d%n", k, hash, bucket);
            }
    
            // null key is always stored in bucket 0
            map.put(null, "null-value");
            System.out.println("null key → " + map.get(null));
    
            System.out.println("Size: " + map.size());
        }
    }
