    What is immutable class
    
    ```java
    import java.util.ArrayList;
    import java.util.Collections;
    import java.util.List;
    
    // Immutable class recipe:
    // 1. final class (no subclassing)
    // 2. private final fields
    // 3. no setters
    // 4. deep-copy mutable fields (e.g. List)
    public final class ImmutablePerson {
        private final String name;
        private final int age;
        private final List hobbies; // mutable field — needs deep copy
    
        public ImmutablePerson(String name, int age, List hobbies) {
            this.name = name;
            this.age = age;
            // Deep copy: don't store the caller's list directly
            this.hobbies = new ArrayList<>(hobbies);
        }
    
        public String getName()  { return name; }
        public int getAge()      { return age; }
    
        // Return a copy — never expose the internal list
        public List getHobbies() {
            return Collections.unmodifiableList(hobbies);
        }
    
        @Override
        public String toString() {
            return name + " (age " + age + "): " + hobbies;
        }
    
        public static void main(String[] args) {
            List h = new ArrayList<>();
            h.add("reading");
            h.add("coding");
    
            ImmutablePerson p = new ImmutablePerson("Alice", 30, h);
            System.out.println(p); // Alice (age 30): [reading, coding]
    
            // Mutating the original list doesn't affect p
            h.add("gaming");
            System.out.println(p); // still [reading, coding]
    
            // Trying to mutate the returned list throws
            try {
                p.getHobbies().add("hacking");
            } catch (UnsupportedOperationException e) {
                System.out.println("Cannot modify immutable list!");
            }
    
            // Java 16+ record syntax achieves the same for simple cases:
            // record Point(int x, int y) {}
        }
    }
