    HashTable vs HashMap vs ConcurrentHashmap
    
    ```java
    import java.util.*;
    import java.util.concurrent.*;
    
    public class MapThreadSafety {
        public static void main(String[] args) throws InterruptedException {
    
            // Hashtable: synchronized, legacy, slow
            Hashtable table = new Hashtable<>();
            table.put("a", 1);
            // table.put(null, 1); // NullPointerException!
            System.out.println("Hashtable: " + table);
    
            //HashMap: fast, NOT thread-safe
            HashMap hashMap = new HashMap<>();
            hashMap.put("a", 1);
            hashMap.put(null, 0); // null key allowed
            System.out.println("HashMap: " + hashMap);
    
            // Race condition example (DON'T do this in production):
            // Two threads calling hashMap.put() concurrently can corrupt the map!
    
            // ConcurrentHashMap: thread-safe, high performance
            ConcurrentHashMap concurrent = new ConcurrentHashMap<>();
    
            // Safe atomic operation: increment a counter
            concurrent.put("count", 0);
    
            Runnable increment = () -> {
                for (int i = 0; i < 1000; i++) {
                    concurrent.merge("count", 1, Integer::sum); // atomic!
                }
            };
    
            Thread t1 = new Thread(increment);
            Thread t2 = new Thread(increment);
            t1.start(); t2.start();
            t1.join();  t2.join();
    
            System.out.println("Final count: " + concurrent.get("count")); // 2000
    
            // concurrent.put(null, 1); // NullPointerException!
    
            // Summary table:
            System.out.println("
    Summary:");
            System.out.println("Hashtable:         thread-safe, no null key, legacy");
            System.out.println("HashMap:           not safe,    null key ok, modern");
            System.out.println("ConcurrentHashMap: thread-safe, no null key, best choice");
        }
    }
