    why we need to override the hashcode and equals method at the same time
    
    ```java
    import java.util.*;
    
    public class HashCodeEqualsContract {
    
        // BAD: overrides equals only — breaks HashMap!
        static class BadPoint {
            int x, y;
            BadPoint(int x, int y) { this.x = x; this.y = y; }
    
            @Override
            public boolean equals(Object o) {
                if (!(o instanceof BadPoint)) return false;
                BadPoint p = (BadPoint) o;
                return x == p.x && y == p.y;
            }
            // hashCode NOT overridden → inherits Object.hashCode() (memory address)
        }
    
        // GOOD: overrides both, maintaining the contract
        static class GoodPoint {
            int x, y;
            GoodPoint(int x, int y) { this.x = x; this.y = y; }
    
            @Override
            public boolean equals(Object o) {
                if (this == o) return true;
                if (!(o instanceof GoodPoint)) return false;
                GoodPoint p = (GoodPoint) o;
                return x == p.x && y == p.y;
            }
    
            @Override
            public int hashCode() {
                return Objects.hash(x, y); // uses both fields
            }
        }
    
        public static void main(String[] args) {
            // BadPoint breaks HashSet
            Set badSet = new HashSet<>();
            BadPoint b1 = new BadPoint(1, 2);
            BadPoint b2 = new BadPoint(1, 2);
    
            System.out.println("b1.equals(b2): " + b1.equals(b2)); // true
            badSet.add(b1);
            badSet.add(b2); // should be duplicate, but...
            System.out.println("BadPoint set size: " + badSet.size()); // 2 (BUG!)
    
            // GoodPoint works correctly
            Set goodSet = new HashSet<>();
            GoodPoint g1 = new GoodPoint(1, 2);
            GoodPoint g2 = new GoodPoint(1, 2);
    
            System.out.println("g1.equals(g2): " + g1.equals(g2)); // true
            goodSet.add(g1);
            goodSet.add(g2);
            System.out.println("GoodPoint set size: " + goodSet.size()); // 1 (correct!)
    
            // Also works as Map key
            Map map = new HashMap<>();
            map.put(g1, "origin area");
            System.out.println("Lookup g2: " + map.get(g2)); // "origin area" ✓
        }
    }
