    import java.util.*;
    
    public class CollectionsUtility {
        public static void main(String[] args) {
            List nums = new ArrayList<>(Arrays.asList(5, 3, 8, 1, 9, 2));
    
            // Sorting
            Collections.sort(nums);
            System.out.println("Sorted: " + nums); // [1, 2, 3, 5, 8, 9]
    
            // Reverse order
            Collections.sort(nums, Collections.reverseOrder());
            System.out.println("Reversed: " + nums); // [9, 8, 5, 3, 2, 1]
    
            // Binary search (list must be sorted first)
            Collections.sort(nums);
            int idx = Collections.binarySearch(nums, 5);
            System.out.println("Found 5 at index: " + idx);
    
            // Shuffle
            Collections.shuffle(nums);
            System.out.println("Shuffled: " + nums);
    
            // Min / Max
            System.out.println("Min: " + Collections.min(nums));
            System.out.println("Max: " + Collections.max(nums));
    
            // Frequency
            List words = Arrays.asList("hi", "hello", "hi", "hey", "hi");
            System.out.println("'hi' appears: " + Collections.frequency(words, "hi")); // 3
    
            // Unmodifiable wrapper (read-only view)
            List readOnly = Collections.unmodifiableList(nums);
            try {
                readOnly.add(99); // throws UnsupportedOperationException
            } catch (UnsupportedOperationException e) {
                System.out.println("Cannot modify read-only list!");
            }
    
            // Synchronized wrapper (thread-safe)
            List syncList = Collections.synchronizedList(new ArrayList<>());
            syncList.add(1);
            System.out.println("Thread-safe list: " + syncList);
    
            // Singleton: immutable single-element collection
            List one = Collections.singletonList("only");
            System.out.println("Singleton: " + one);
        }
    }
