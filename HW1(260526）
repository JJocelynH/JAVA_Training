    What is Map Interface
    
    ```java
    import java.util.*;
    
    public class MapInterface {
        public static void main(String[] args) {
            // HashMap: key-value store, O(1) average for get/put
            Map scores = new HashMap<>();
            scores.put("Alice", 95);
            scores.put("Bob", 80);
            scores.put("Charlie", 92);
    
            System.out.println("Alice's score: " + scores.get("Alice")); // 95
            System.out.println("Contains Bob: " + scores.containsKey("Bob")); // true
    
            // Update a value
            scores.put("Bob", 85);
    
            // Iterate entries
            for (Map.Entry entry : scores.entrySet()) {
                System.out.println(entry.getKey() + " → " + entry.getValue());
            }
    
            // getOrDefault: safe get with fallback
            int dave = scores.getOrDefault("Dave", 0);
            System.out.println("Dave: " + dave); // 0
    
            // putIfAbsent: only inserts if key is missing
            scores.putIfAbsent("Alice", 100); // ignored, Alice exists
            System.out.println("Alice still: " + scores.get("Alice")); // 95
    
            // LinkedHashMap: preserves insertion order
            Map linked = new LinkedHashMap<>(scores);
            System.out.println("LinkedHashMap keys: " + linked.keySet());
    
            // TreeMap: sorted by key
            Map tree = new TreeMap<>(scores);
            System.out.println("TreeMap (sorted): " + tree);
        }
    }
    
