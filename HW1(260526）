    ```java
    public class OverloadingDemo {
    
        // Same method name, different parameter signatures
        static int add(int a, int b) {
            System.out.println("int + int");
            return a + b;
        }
    
        static double add(double a, double b) {
            System.out.println("double + double");
            return a + b;
        }
    
        static int add(int a, int b, int c) {
            System.out.println("int + int + int");
            return a + b + c;
        }
    
        static String add(String a, String b) {
            System.out.println("String + String");
            return a + b;
        }
    
        public static void main(String[] args) {
            System.out.println(add(1, 2));           // int + int → 3
            System.out.println(add(1.5, 2.5));       // double + double → 4.0
            System.out.println(add(1, 2, 3));         // int + int + int → 6
            System.out.println(add("Hello", " World")); // String + String
    
            // Resolution is at COMPILE TIME based on argument types
            // Changing runtime types doesn't affect which overload is called
        }
    
        // Rules:
        // ✓ Different number of parameters
        // ✓ Different parameter types
        // ✓ Different parameter order (generally bad practice)
        // ✗ Return type alone is NOT enough to distinguish overloads
        // ✗ Access modifier changes alone are NOT overloading
    }
