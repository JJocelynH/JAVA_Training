    Comparator vs Comparable, when to use which one
    
    ```java
    import java.util.*;
    
    // Comparable: class defines its OWN natural ordering
    public class Student implements Comparable {
        String name;
        int gpa;  // sort by GPA by default
    
        Student(String name, int gpa) {
            this.name = name;
            this.gpa = gpa;
        }
    
        @Override
        public int compareTo(Student other) {
            // Return negative → this comes first
            // Return 0        → equal
            // Return positive → other comes first
            return Integer.compare(other.gpa, this.gpa); // descending GPA
        }
    
        @Override
        public String toString() {
            return name + "(" + gpa + ")";
        }
    
        public static void main(String[] args) {
            List students = new ArrayList<>();
            students.add(new Student("Alice", 88));
            students.add(new Student("Bob",   95));
            students.add(new Student("Carol", 72));
    
            Collections.sort(students); // uses compareTo() — no extra arg
            System.out.println(students);
            // [Bob(95), Alice(88), Carol(72)]
    
            // Also works with TreeSet (natural order)
            TreeSet set = new TreeSet<>(students);
            System.out.println("First: " + set.first()); // Bob(95)
        }
    }
